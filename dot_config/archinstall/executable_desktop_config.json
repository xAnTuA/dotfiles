{
    "app_config": {
        "audio_config": {
            "audio": "pipewire"
        },
        "bluetooth_config": {
            "enabled": true
        },
        "firewall_config": {
            "firewall": "ufw"
        },
        "print_service_config": {
            "enabled": true
        }
    },
    "archinstall-language": "English",
    "auth_config": null,
    "bootloader_config": {
        "bootloader": "Grub",
        "removable": true,
        "uki": false
    },
    "custom_commands": [
		 "su - $(ls /home | head -n 1) -c  'chezmoi init --apply --force https://github.com/xAnTuA/dotfiles.git'",
		 "USER=$(ls /home | head -n 1); su - $USER -c 'cd ~ && git clone https://aur.archlinux.org/yay-bin.git && cd yay-bin && makepkg -s --noconfirm' && pacman -U /home/$USER/yay-bin/*.pkg.tar.zst --noconfirm && rm -rf /home/$USER/yay-bin",
		 "su - $(ls /home | head -n 1) -c 'curl https://raw.githubusercontent.com/oh-my-fish/oh-my-fish/master/bin/install > install; fish install --path=~/.local/share/omf --config=~/.config/omf -y --noninteractive'",
		 "chsh $(ls /home | head -n 1) -s /usr/bin/fish",
     "su - $(ls /home | head -n 1) -c 'nvim -c \"MasonInstallAll\" -c \"TSInstallAll\" -c \"quitall\"'"
	 ],
    "hostname": "archlinux",
    "kernels": [
        "linux"
    ],
    "locale_config": {
        "kb_layout": "us",
        "sys_enc": "UTF-8",
        "sys_lang": "en_US.UTF-8"
    },
    "mirror_config": {
        "custom_repositories": [],
        "custom_servers": [],
        "mirror_regions": {
            "Poland": [
                "http://arch.midov.pl/arch/$repo/os/$arch",
                "https://arch.midov.pl/arch/$repo/os/$arch",
                "http://ftp.icm.edu.pl/pub/Linux/dist/archlinux/$repo/os/$arch",
                "https://ftp.icm.edu.pl/pub/Linux/dist/archlinux/$repo/os/$arch",
                "http://mirror.juniorjpdj.pl/archlinux/$repo/os/$arch",
                "https://mirror.juniorjpdj.pl/archlinux/$repo/os/$arch",
                "http://ftp.psnc.pl/linux/archlinux/$repo/os/$arch",
                "https://ftp.psnc.pl/linux/archlinux/$repo/os/$arch",
                "http://arch.sakamoto.pl/$repo/os/$arch",
                "https://arch.sakamoto.pl/$repo/os/$arch",
                "https://mirror.przekichane.pl/archlinux/$repo/os/$arch",
                "http://mirror.alldaydev.com/archlinux/$repo/os/$arch",
                "https://mirror.alldaydev.com/archlinux/$repo/os/$arch"
            ]
        },
        "optional_repositories": []
    },
    "network_config": {
        "type": "nm"
    },
    "ntp": true,
    "packages": [
        "7zip",
        "base-devel",
        "bitwarden",
        "bitwarden-cli",
        "blender",
        "chezmoi",
        "firefox",
        "gimp",
        "inkscape",
        "neovim",
        "rofi",
        "unrar",
        "zip",
        "obs-studio",
        "dolphin",
        "virtualbox",
        "picom",
        "proton-vpn-cli",
        "kitty",
        "git",
        "scrot",
        "fish",
        "feh",
        "konsole",
        "npm",
        "unzip",
        "zoxide",
        "bc",
        "man",
        "tree-sitter-cli",
        "ripgrep",
        "ttf-jetbrains-mono-nerd",
        "ttf-nerd-fonts-symbols-common",
        "docker",
        "proton-vpn-gtk-app",
        "qbittorrent",
        "libreoffice-fresh",
        "rust",
        "blueman",
        "xclip"
    ],
    "parallel_downloads": 0,
    "profile_config": {
        "gfx_driver": "All open-source",
        "greeter": "ly",
        "profile": {
            "custom_settings": {
                "i3-wm": {}
            },
            "details": [
                "i3-wm"
            ],
            "main": "Desktop"
        }
    },
    "script": null,
    "services": [],
    "swap": {
        "algorithm": "zstd",
        "enabled": true
    },
    "timezone": "Europe/Warsaw",
    "version": "4.1"
}
